# --- Banco principal (presenca_aom) ---
DB_HOST=localhost
DB_NAME=presenca_aom
DB_USER=root
DB_PASS=SUA_SENHA_AQUI

# --- Banco RackTables (outro servidor) ---
RACK_DB_HOST=10.144.128.22
RACK_DB_NAME=racktables_db
RACK_DB_USER=usuario_rack
RACK_DB_PASS=SUA_SENHA_RACK_AQUI

# --- WhatsApp API (token Bearer padrão / fallback) ---
WHATSAPP_API_URL_MESSAGE=http://10.144.128.34:21465/api/servidor/send-message
WHATSAPP_API_URL_FILE=http://10.144.128.34:21465/api/servidor/send-file
WHATSAPP_API_TOKEN=Bearer SEU_TOKEN_AQUI

# --- Timezone padrão ---
APP_TIMEZONE=America/Cuiaba
